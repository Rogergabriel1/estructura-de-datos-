    elif opcion == 3:
        base = int(input("Ingrese la base: "))
        exponente = int(input("Ingrese el exponente: "))
        print("Potencia:", potencia(base, exponente))

    elif opcion == 0:
        print("El programa cerró correctamente")

    else:
